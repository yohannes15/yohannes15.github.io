---
import PageLayout from '../../layouts/PageLayout.astro';
import { getPortfolioProjects } from '../../lib/github-projects';
import { marked } from 'marked';

export async function getStaticPaths() {
  const projects = await getPortfolioProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Awaited<ReturnType<typeof getPortfolioProjects>>[number];
}

const { project } = Astro.props;

const { title, subtitle, github, demo, thumb, content } = project;

// Render markdown content to HTML
const htmlContent = marked.parse(content);
---

<PageLayout title={title} description={subtitle}>
  <nav class="muted-note" aria-label="Breadcrumb">
    <a href="/projects/">← All projects</a>
  </nav>
  <article class="project-detail">
    <header style="margin: 1.25rem 0 1rem">
      <h1 style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(1.8rem, 3vw, 2.3rem); margin: 0 0 0.5rem">
        {title}
      </h1>
      <p class="project-intro" style="margin: 0 0 1rem">{subtitle}</p>
      <div class="contact-row">
        <a class="pill-link" href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
        {demo && (
          <a class="pill-link pill-muted" href={demo} target="_blank" rel="noopener noreferrer">
            Live demo
          </a>
        )}
      </div>
    </header>
    <img class="project-hero-thumb" src={thumb} alt="" width="960" height="540" loading="eager" />
    <div class="prose" style="margin-top: 1.35rem" set:html={htmlContent} />
  </article>
</PageLayout>
