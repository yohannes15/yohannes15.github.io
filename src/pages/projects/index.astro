---
import PageLayout from '../../layouts/PageLayout.astro';
import { getPortfolioProjects } from '../../lib/github-projects';

const allProjects = await getPortfolioProjects();

const projects = allProjects.filter(p => 
  p.tags.includes('Active') || 
  p.tags.includes('Stale') || 
  p.tags.includes('Demo') ||
  p.tags.includes('Showcase')
);

const learning = allProjects.filter(p => 
  p.tags.includes('Learning') && 
  !p.tags.includes('Active') && 
  !p.tags.includes('Stale') &&
  !p.tags.includes('Demo') &&
  !p.tags.includes('Showcase')
);
---

<PageLayout
  title="Projects"
  description="Side projects, experiments, and learning explorations in backend development, functional programming, and data systems."
>
  <section class="block" style="margin-bottom: 3rem">
    <header class="section-head">
      <h1>Projects</h1>
    </header>
    <div class="project-grid" style="margin-top: 1rem">
      {
        projects.map((p) => (
          <article class="project-card">
            <a class="project-thumb-wrap" href={`/projects/${p.slug}/`} tabindex="-1" aria-hidden="true">
              <img src={p.thumb} alt="" width="640" height="360" loading="lazy" />
            </a>
          <div class="project-body">
            {p.tags && p.tags.length > 0 && (
              <div class="project-tags">
                {p.language && (
                  <span class={`tag tag-language`}>{p.language}</span>
                )}
                {p.tags.map((tag) => (
                  <span class={`tag tag-${tag.toLowerCase()}`}>{tag}</span>
                ))}
              </div>
            )}
            <h2 style="margin: 0 0 0.4rem; font-size: 1.15rem">
                <a href={`/projects/${p.slug}/`}>{p.title}</a>
              </h2>
              <p class="project-lede">{p.subtitle}</p>
            </div>
            <div class="project-actions">
              <a class="pill-link" href={p.github} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
              {p.demo && (
                <a class="pill-link pill-muted" href={p.demo} target="_blank" rel="noopener noreferrer">
                  Live demo
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="block" id="learning">
    <header class="section-head">
      <h2>Learning & Practice</h2>
    </header>
    <div class="project-grid" style="margin-top: 1rem">
      {
        learning.map((p) => (
          <article class="project-card">
            <a class="project-thumb-wrap" href={`/projects/${p.slug}/`} tabindex="-1" aria-hidden="true">
              <img src={p.thumb} alt="" width="640" height="360" loading="lazy" />
            </a>
          <div class="project-body">
            {p.tags && p.tags.length > 0 && (
              <div class="project-tags">
                {p.language && (
                  <span class={`tag tag-language`}>{p.language}</span>
                )}
                {p.tags.map((tag) => (
                  <span class={`tag tag-${tag.toLowerCase()}`}>{tag}</span>
                ))}
              </div>
            )}
            <h2 style="margin: 0 0 0.4rem; font-size: 1.15rem">
                <a href={`/projects/${p.slug}/`}>{p.title}</a>
              </h2>
              <p class="project-lede">{p.subtitle}</p>
            </div>
            <div class="project-actions">
              <a class="pill-link" href={p.github} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
              {p.demo && (
                <a class="pill-link pill-muted" href={p.demo} target="_blank" rel="noopener noreferrer">
                  Live demo
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</PageLayout>
