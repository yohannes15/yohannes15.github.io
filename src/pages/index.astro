          </div>
          <div class="skill-logo-item">
            <img src="https://cdn.simpleicons.org/flask/000000" alt="Flask" width="32" height="32" />
            <span>Flask</span>
            <div class="skill-bar"><div class="skill-bar-fill" style="width: 80%"></div></div>
          </div>
          <div class="skill-logo-item">
            <img src="https://cdn.simpleicons.org/fastapi/009688" alt="FastAPI" width="32" height="32" />
            <span>FastAPI</span>
            <div class="skill-bar"><div class="skill-bar-fill" style="width: 50%"></div></div>
          </div>
          <div class="skill-logo-item">
            <img src="https://cdn.simpleicons.org/pytest/0A9EDC" alt="Pytest" width="32" height="32" />
            <span>Pytest</span>
            <div class="skill-bar"><div class="skill-bar-fill" style="width: 80%"></div></div>
