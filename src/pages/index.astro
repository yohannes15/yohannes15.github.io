---
import PageLayout from '../layouts/PageLayout.astro';
import { getPortfolioProjects, tagsForProjectCard, formatLastPushDate } from '../lib/github-projects';

const allProjects = await getPortfolioProjects();

const projects = allProjects.filter(p => 
  p.tags.includes('Demo') || p.tags.includes('Showcase')
);

const learning = allProjects.filter(p => 
  p.tags.includes('Learning') && 
  !p.tags.includes('Demo') &&
  !p.tags.includes('Showcase')
);

const TECH_TAGS = ['Python · Django · Flask · FastAPI', 'Scala · Cats · Http4s', 'Go', 'AWS · GCP'];

const profilePhoto = 'https://avatars.githubusercontent.com/u/48221308?v=5';

type SkillItem = { name: string; src: string; alt: string; level: number };

const skillCategories: { title: string; context?: { label: string; hint: string }; items: SkillItem[] }[] = [
  {
    title: 'Languages',
    items: [
      { name: 'Python',     src: 'https://cdn.simpleicons.org/python/3776AB',     alt: 'Python',     level: 90 },
      { name: 'Scala',      src: 'https://cdn.simpleicons.org/scala/DC322F',      alt: 'Scala',      level: 65 },
      { name: 'C#',         src: '/logos/csharp-logo.svg',                        alt: 'C#',         level: 60 },
      { name: 'TypeScript', src: 'https://cdn.simpleicons.org/typescript/3178C6', alt: 'TypeScript', level: 40 },
      { name: 'Go',         src: 'https://cdn.simpleicons.org/go/00ADD8',         alt: 'Go',         level: 30 },
    ],
  },
  {
    title: 'Backend',
    items: [
      { name: 'Django',    src: 'https://cdn.simpleicons.org/django/092E20',   alt: 'Django',    level: 90 },
      { name: 'Flask',     src: 'https://cdn.simpleicons.org/flask/000000',    alt: 'Flask',     level: 80 },
      { name: 'FastAPI',   src: 'https://cdn.simpleicons.org/fastapi/009688',  alt: 'FastAPI',   level: 60 },
      { name: 'Http4s',    src: 'https://http4s.org/images/http4s-logo.svg',   alt: 'Http4s',    level: 55 },
      { name: '.NET Core', src: 'https://cdn.simpleicons.org/dotnet/512BD4',   alt: '.NET Core', level: 40 },
    ],
  },
  {
    title: 'Frontend',
    context: {
      label: 'Earlier roles',
      hint: 'Skills from earlier roles, usable when needed, not where I am focused now.',
    },
    items: [
      { name: 'HTML/CSS',   src: 'https://cdn.simpleicons.org/html5/E34F26',          alt: 'HTML/CSS',   level: 70 },
      { name: 'Tailwind',   src: 'https://cdn.simpleicons.org/tailwindcss/06B6D4',    alt: 'Tailwind',   level: 65 },
      { name: 'HTMX',       src: 'https://cdn.simpleicons.org/htmx/3366CC',           alt: 'HTMX',       level: 65 },
      { name: 'Alpine.js',  src: 'https://cdn.simpleicons.org/alpinedotjs/8BC0D0',    alt: 'Alpine.js',  level: 60 },
      { name: 'React',      src: 'https://cdn.simpleicons.org/react/61DAFB',          alt: 'React',      level: 50 },
    ],
  },
  {
    title: 'Cloud & Infrastructure',
    items: [
      { name: 'Docker',          src: 'https://cdn.simpleicons.org/docker/2496ED',       alt: 'Docker',          level: 80 },
      { name: 'GCP',             src: '/logos/gcp-logo.svg',                             alt: 'GCP',             level: 70 },
      { name: 'AWS',             src: '/logos/aws-logo.png',                             alt: 'AWS',             level: 70 },
      { name: 'GH Actions',  src: 'https://cdn.simpleicons.org/githubactions/2088FF',alt: 'GitHub Actions',  level: 60 },
      { name: 'Terraform',       src: 'https://cdn.simpleicons.org/terraform/7B42BC',    alt: 'Terraform',       level: 45 },
      { name: 'Scalr',           src: '/logos/scalr-logo.svg',                           alt: 'Scalr',           level: 40 },
    ],
  },
  {
    title: 'Databases',
    items: [
      { name: 'PostgreSQL', src: 'https://cdn.simpleicons.org/postgresql/4169E1', alt: 'PostgreSQL', level: 85 },
      { name: 'Redis',      src: 'https://cdn.simpleicons.org/redis/DC382D',      alt: 'Redis',      level: 75 },
      { name: 'DynamoDB',   src: '/logos/dynamodb-logo.png',                      alt: 'DynamoDB',   level: 60 },
      { name: 'Snowflake',  src: 'https://cdn.simpleicons.org/snowflake/29B5E8',  alt: 'Snowflake',  level: 50 },
      { name: 'MongoDB',    src: 'https://cdn.simpleicons.org/mongodb/47A248',    alt: 'MongoDB',    level: 35 },
    ],
  },
  {
    title: 'Tools & Libraries',
    items: [
      { name: 'Pytest',   src: 'https://cdn.simpleicons.org/pytest/0A9EDC',   alt: 'Pytest',              level: 80 },
      { name: 'Cats & CE',src: '/logos/cats-logo.png',                        alt: 'Cats & Cats Effect',  level: 65 },
      { name: 'Pandas',   src: '/logos/pandas-logo.svg',                      alt: 'Pandas',              level: 60 },
      { name: 'Datadog',  src: 'https://cdn.simpleicons.org/datadog/632CA6',  alt: 'Datadog',             level: 50 },
      { name: 'FS2',      src: 'https://cdn.simpleicons.org/scala/DC322F',    alt: 'FS2',                 level: 45 },
      { name: 'Celery',   src: 'https://cdn.simpleicons.org/celery/37814A',   alt: 'Celery',              level: 45 },
    ],
  },
];
---

<PageLayout
  description="Backend engineer with 6+ years building scalable distributed systems in Python, Scala, and cloud infrastructure."
>
  <section class="hero" aria-labelledby="intro-heading">
    <img
      class="avatar"
      src={profilePhoto}
      width="120"
      height="120"
      alt="Portrait of Yohannes Berhane"
      loading="eager"
    />
    <div class="lede">
      <h1 id="intro-heading">Backend Software Engineer</h1>
      <p class="lede-sub">
        Backend engineer with 6+ years building scalable distributed systems. 
        Expert in <strong>Python</strong> (Django, Flask, FastAPI) with growing proficiency in <strong>Scala</strong> (Cats, Cats Effect, Http4s) and <strong>Go</strong>. 
        Led infrastructure migrations handling 700K+ requests per day and scaled systems serving 15%+ of US independent mortgage originations.
      </p>
      <div class="education-badge">
        <span class="badge-icon">🎓</span>
        <span><strong>B.S. Computer Science</strong> · St. John's University, Queens NY · 2020</span>
      </div>
      <div class="contact-row">
        <a class="pill-link" href="mailto:y.berhane56@gmail.com">
          <img src="https://cdn.simpleicons.org/gmail/EA4335" alt="" width="16" height="16" style="vertical-align: middle; margin-right: 4px;" />
          Email
        </a>
        <a class="pill-link pill-muted" href="https://www.linkedin.com/in/yohannes-berhane/" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#0A66C2" style="vertical-align: middle; margin-right: 4px;">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a class="pill-link pill-muted" href="https://github.com/yohannes15" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white" style="vertical-align: middle; margin-right: 4px;">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a class="btn-primary" href="/resume/">View resume</a>
      </div>
      <ul class="tag-list" aria-label="Highlights">
        {TECH_TAGS.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </section>

  <section class="block" aria-labelledby="exp-heading">
    <div class="section-head">
      <h2 id="exp-heading">Experience</h2>
    </div>
    <div class="experience-timeline">
      <article class="exp-card">
        <div class="exp-header">
          <div class="exp-company-logo">
            <img src="/logos/gen-logo.png" alt="Gen" width="48" height="48" />
          </div>
          <div class="exp-header-text">
            <h3 class="exp-title">Senior Software Engineer</h3>
            <div class="exp-company">Gen</div>
            <div class="exp-meta">
              <span>Oct 2025 – May 2026</span>
              <span class="exp-divider">·</span>
              <span>New York, NY (Hybrid)</span>
            </div>
          </div>
          <div class="exp-highlights">
            <div class="exp-highlight">
              <div class="exp-highlight-value">700K+</div>
              <div class="exp-highlight-label">Requests/Day</div>
            </div>
            <div class="exp-highlight">
              <div class="exp-highlight-value">5M+</div>
              <div class="exp-highlight-label">Leads/Month</div>
            </div>
          </div>
        </div>
        <ul class="exp-list">
          <li>
            Led the in-sourcing and migration of an outsourced Django application (~700K requests/day) from EC2 to ECS and RDS to Aurora;
            implemented IaC with Terraform to eliminate manual overhead and improve reliability.
          </li>
          <li>
            Developed internal rule-based decision engines using Scala, Cats, and Http4s, while managing partner integrations via a
            high-throughput Django REST platform.
          </li>
          <li>
            Designed a data pipeline (Snowflake → S3 → Lambda → SQS → application) to process over 5 million leads monthly for automated offer refreshes.
          </li>
          <li>
            Supported a decisioning platform for credit card partners, enabling secure execution of partner-provided decision engines via containerized environments.
          </li>
        </ul>
      </article>

      <article class="exp-card">
        <div class="exp-header">
          <div class="exp-company-logo">
            <img src="/logos/optifunder-logo.png" alt="OptiFunder" width="48" height="48" />
          </div>
          <div class="exp-header-text">
            <h3 class="exp-title">Senior Software Engineer</h3>
            <div class="exp-company">OptiFunder</div>
            <div class="exp-meta">
              <span>Sep 2021 – Oct 2025</span>
              <span class="exp-divider">·</span>
              <span>Promoted May 2023</span>
              <span class="exp-divider">·</span>
              <span>Remote, NY</span>
            </div>
          </div>
          <div class="exp-highlights">
            <div class="exp-highlight">
              <div class="exp-highlight-value">15%</div>
              <div class="exp-highlight-label">US Market</div>
            </div>
            <div class="exp-highlight">
              <div class="exp-highlight-value">200%</div>
              <div class="exp-highlight-label">Query Speed</div>
            </div>
          </div>
        </div>
        <ul class="exp-list">
          <li>
            Led the design and development of high-performance Django and Flask applications, serving over 15% of all US independent mortgage originations;
            utilized a modern frontend stack of HTMX, Alpine.js, and React with Tailwind CSS.
          </li>
          <li>
            Orchestrated the migration to a microservices-based architecture for the loan optimization engine, leveraging asyncio, threading,
            and distributed tasks via Google Cloud Tasks/Jobs.
          </li>
          <li>
            Engineered and maintained robust RESTful APIs using Django REST Framework, ensuring high availability and secure data processing.
          </li>
          <li>
            Redesigned and normalized legacy database schemas, resulting in a 200% improvement in query performance and overall system efficiency.
          </li>
          <li>
            Managed large-scale cloud deployments on GCP using Terraform (IaC), while establishing comprehensive testing standards with Pytest.
          </li>
          <li>
            Mentored a team of 3-5 developers, driving technical decisions, conducting code reviews, and steering the product roadmap.
          </li>
        </ul>
      </article>

      <article class="exp-card">
        <div class="exp-header">
          <div class="exp-company-logo">
            <img src="/logos/trimble-logo.png" alt="Trimble" width="48" height="48" />
          </div>
          <div class="exp-header-text">
            <h3 class="exp-title">Software Engineer</h3>
            <div class="exp-company">Trimble Maps</div>
            <div class="exp-meta">
              <span>Oct 2020 – Oct 2021</span>
              <span class="exp-divider">·</span>
              <span>Princeton, NJ</span>
            </div>
          </div>
          <div class="exp-highlights">
            <div class="exp-highlight">
              <div class="exp-highlight-value">15%</div>
              <div class="exp-highlight-label">Faster Deploys</div>
            </div>
            <div class="exp-highlight">
              <div class="exp-highlight-value">30%</div>
              <div class="exp-highlight-label">Query Speed</div>
            </div>
          </div>
        </div>
        <ul class="exp-list">
          <li>
            Developed backend services using .NET Core and deployed in Docker containers on AWS to support high-volume GPS mapping and logistics operations.
          </li>
          <li>
            Automated CI/CD pipelines using Jenkins, Python, and Chef, reducing deployment times by 15%.
          </li>
          <li>
            Modernized REST and SOAP services using ASP.NET Web APIs, ensuring high availability with blue-green deployment strategies.
          </li>
          <li>
            Wrote unit tests for APIs using NUnit and XUnit, achieving 85% code coverage.
          </li>
          <li>
            Enhanced SQL Server database transactions and performance, reducing query response times by 30%.
          </li>
        </ul>
      </article>
    </div>
  </section>

  <section class="block block-compact" aria-labelledby="opensource-heading">
    <div class="section-head">
      <h2 id="opensource-heading">Open Source</h2>
    </div>
    <article class="contrib-card">
      <div class="contrib-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <h3>Django Storages</h3>
        <a href="https://github.com/jschneier/django-storages/pull/1427" target="_blank" rel="noopener noreferrer" class="contrib-link">
          PR #1427 →
        </a>
      </div>
      <p class="contrib-desc">
        Developed feature for Google Cloud Compute services to generate signed URLs via IAM API. 
        Collaborated with maintainers to ensure secure integration that benefits the broader community.
      </p>
    </article>
  </section>

  <section class="block" aria-labelledby="skills-heading">
    <div class="section-head">
      <h2 id="skills-heading">Technical Skills</h2>
    </div>
    <div class="skills-grid-new">
      {skillCategories.map((category) => (
        <article class="skill-category">
          <div class="skill-category-heading">
            <h3>{category.title}</h3>
            {category.context && (
              <span
                class="skill-category-context"
                data-hint={category.context.hint}
                aria-label={`${category.context.label}. ${category.context.hint}`}
                role="note"
                tabindex="0"
              >
                <svg
                  class="skill-category-context-icon"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h18.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                  <path d="M12 9v4" />
                  <path d="M12 17h.01" />
                </svg>
                <span class="skill-category-context-label">{category.context.label}</span>
              </span>
            )}
          </div>
          <div class="skill-logos">
            {category.items.map((skill) => (
              <div class="skill-logo-item">
                <img src={skill.src} alt={skill.alt} width="32" height="32" />
                <span>{skill.name}</span>
                <div class="skill-bar"><div class="skill-bar-fill" style={`width: ${skill.level}%`}></div></div>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="block" aria-labelledby="projects-heading" style="margin-bottom: 3rem">
    <div class="section-head">
      <h2 id="projects-heading">Projects</h2>
      <a class="muted-note" href="/projects/"> View all » </a>
    </div>
    <div class="project-grid">
      {
        projects.slice(0, 3).map((p) => (
          <article class="project-card">
            <a class="project-thumb-wrap" href={`/projects/${p.slug}/`} tabindex="-1" aria-hidden="true">
              <img src={p.thumb} alt="" width="640" height="360" loading="lazy" />
            </a>
            <div class="project-body">
              {(p.language || tagsForProjectCard(p.tags).length > 0) && (
                <div class="project-tags">
                  {p.language && (
                    <span class={`tag tag-language`}>{p.language}</span>
                  )}
                  {tagsForProjectCard(p.tags).map((tag) => (
                    <span class={`tag tag-${tag.toLowerCase()}`}>{tag}</span>
                  ))}
                </div>
              )}
              <h3>
                <a href={`/projects/${p.slug}/`}>{p.title}</a>
              </h3>
              <p class="project-lede">{p.subtitle}</p>
              <p class="project-last-push">
                Last push{' '}
                <time datetime={p.lastPushAt}>{formatLastPushDate(p.lastPushAt)}</time>
              </p>
            </div>
            <div class="project-actions">
              <a class="pill-link" href={p.github} target="_blank" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </a>
              {p.demo && (
                <a class="pill-link pill-demo" href={p.demo} target="_blank" rel="noopener noreferrer">
                  Live Demo
                </a>
              )}
              <a class="pill-link pill-muted" href={`/projects/${p.slug}/`}>
                Details
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="block" aria-labelledby="learning-heading">
    <div class="section-head">
      <h2 id="learning-heading">Learning & Practice</h2>
      <a class="muted-note" href="/projects/#learning"> View all » </a>
    </div>
    <div class="project-grid">
      {
        learning.slice(0, 3).map((p) => (
          <article class="project-card">
            <a class="project-thumb-wrap" href={`/projects/${p.slug}/`} tabindex="-1" aria-hidden="true">
              <img src={p.thumb} alt="" width="640" height="360" loading="lazy" />
            </a>
            <div class="project-body">
              {(p.language || tagsForProjectCard(p.tags).length > 0) && (
                <div class="project-tags">
                  {p.language && (
                    <span class={`tag tag-language`}>{p.language}</span>
                  )}
                  {tagsForProjectCard(p.tags).map((tag) => (
                    <span class={`tag tag-${tag.toLowerCase()}`}>{tag}</span>
                  ))}
                </div>
              )}
              <h3>
                <a href={`/projects/${p.slug}/`}>{p.title}</a>
              </h3>
              <p class="project-lede">{p.subtitle}</p>
              <p class="project-last-push">
                Last push{' '}
                <time datetime={p.lastPushAt}>{formatLastPushDate(p.lastPushAt)}</time>
              </p>
            </div>
            <div class="project-actions">
              <a class="pill-link" href={p.github} target="_blank" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
