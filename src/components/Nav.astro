---
const rawPath = Astro.url.pathname;
const pathSegment = rawPath.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-current={pathSegment === '/' ? 'page' : undefined}>Yohannes Berhane</a>
            <nav class="nav" aria-label="Primary">
              <a href="/" aria-current={pathSegment === '/' ? 'page' : undefined}>Home</a>
              <a href="/about/" aria-current={pathSegment.startsWith('/about') ? 'page' : undefined}>About</a>
              <a href="/projects/" aria-current={pathSegment.startsWith('/projects') ? 'page' : undefined}>Projects</a>
              <a href="/resume/" aria-current={pathSegment.startsWith('/resume') ? 'page' : undefined}>Resume</a>
            </nav>
  </div>
</header>
